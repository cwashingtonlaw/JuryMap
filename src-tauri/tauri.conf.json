{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JuryMAP",
  "version": "0.1.0",
  "identifier": "com.danielswashington.juryselection",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JuryMAP",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Louisiana criminal voir dire companion",
    "longDescription": "A solo-use, offline-first app for taking juror notes, tracking strikes with Batson analysis, and producing a PDF record of voir dire."
  }
}
