{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the Jury Selection app: native file save/open dialogs and reading/writing .jury files chosen by the user.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**/*.jury"
        },
        {
          "path": "**/*.json"
        }
      ]
    }
  ]
}
